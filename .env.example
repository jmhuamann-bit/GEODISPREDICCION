# Copiar este archivo a ".env" y completar los valores para desarrollo local.
# En Render, estas mismas variables se configuran en el dashboard (o via render.yaml) — nunca
# subir un archivo .env real a git.

# --- Núcleo Flask ---
FLASK_ENV=development
SECRET_KEY=cambia-esto-por-una-cadena-aleatoria-larga-en-produccion

# --- Base de datos ---
# En desarrollo: dejar vacío para usar SQLite automáticamente (instance/geodis.db).
# En produccion (Render): se inyecta automáticamente desde la base de datos PostgreSQL del blueprint.
# DATABASE_URL=postgresql://usuario:password@host:5432/geodispredice

# --- Modelo de IA ---
RISK_ALERT_THRESHOLD_PCT=80

# --- Integraciones externas (opcionales, dejar vacías si no se usan) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_ID=

TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

OPENWEATHER_API_KEY=
MAPBOX_TOKEN=

# --- Logging ---
LOG_LEVEL=INFO
